// Restaurant POS System — Prisma schema
// SQLite for offline-first local storage. All data stays on the restaurant machine.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---- Menu ---------------------------------------------------------------
model MenuItem {
  id        String   @id @default(cuid())
  name      String
  category  String   @default("General")
  price     Float
  cost      Float    @default(0)
  stock     Int      @default(0)
  unit      String   @default("Pcs")
  image     String?  // URL or base64 data URI
  available Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems OrderItem[]

  @@index([category])
}

// ---- Tables -------------------------------------------------------------
model RestaurantTable {
  id             String  @id @default(cuid())
  number         Int     @unique
  name           String  @default("Table")
  capacity       Int     @default(4)
  status         String  @default("available") // available | occupied
  currentOrderId String? @unique

  // All historical orders for this table
  orders        Order[]         @relation("TableOrders")
  currentOrder  Order?          @relation("TableCurrentOrder", fields: [currentOrderId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---- Orders -------------------------------------------------------------
// status lifecycle:
//   open       — accumulating items at the table
//   sent       — KOT pushed to kitchen
//   preparing  — kitchen acknowledged
//   ready      — kitchen marked all items ready
//   served     — counter acknowledged delivery
//   billed     — bill generated, awaiting payment
//   paid       — bill cleared → moves to history, table released
model Order {
  id          String   @id @default(cuid())
  tableId     String
  status      String   @default("open")
  type        String   @default("dine_in") // dine_in | takeaway | direct
  guests      Int      @default(1)
  waiterName  String?
  customerName String?
  notes       String?
  kotPrinted  Boolean  @default(false)
  billPrinted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  table        RestaurantTable @relation("TableOrders", fields: [tableId], references: [id])
  asCurrent    RestaurantTable? @relation("TableCurrentOrder")
  items        OrderItem[]
  bill         Bill?

  @@index([tableId])
  @@index([status])
}

// ---- Order Items --------------------------------------------------------
model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  menuItemId String
  name       String   // snapshot of menu name at time of order
  price      Float    // snapshot of price
  quantity   Int      @default(1)
  status     String   @default("pending") // pending | preparing | ready | served | cancelled
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@index([orderId])
  @@index([status])
}

// ---- Bills (history) ----------------------------------------------------
model Bill {
  id            String   @id @default(cuid())
  billNo        Int      @unique
  orderId       String   @unique
  tableNumber   Int
  subtotal      Float
  taxRate       Float    @default(0.0)
  taxAmount     Float    @default(0.0)
  discount      Float    @default(0.0)
  serviceCharge Float    @default(0.0)
  total         Float
  paymentMode   String   @default("cash") // cash | card | upi | other
  paymentStatus String   @default("paid")
  paidAt        DateTime @default(now())
  createdAt     DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([paidAt])
  @@index([tableNumber])
}

// ---- Customers ----------------------------------------------------------
model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  address   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([phone])
}

// ---- Suppliers ----------------------------------------------------------
model Supplier {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  address   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

// ---- Purchases (stock in) ----------------------------------------------
model Purchase {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique
  supplierId    String?
  supplierName  String?
  subtotal      Float
  taxAmount     Float    @default(0)
  total         Float
  paymentMode   String   @default("cash")
  notes         String?
  items         String   // JSON: [{ name, qty, price, total }]
  createdAt     DateTime @default(now())

  @@index([createdAt])
}

// ---- Expenses -----------------------------------------------------------
model Expense {
  id          String   @id @default(cuid())
  category    String
  description String
  amount      Float
  paymentMode String   @default("cash")
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([date])
  @@index([category])
}

// ---- Money In (cash inflow other than sales) ---------------------------
model MoneyIn {
  id          String   @id @default(cuid())
  amount      Float
  source      String
  description String?
  partyName   String?
  paymentMode String   @default("cash")
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([date])
}

// ---- Money Out (cash outflow other than purchases/expenses) ------------
model MoneyOut {
  id          String   @id @default(cuid())
  amount      Float
  purpose     String
  description String?
  partyName   String?
  paymentMode String   @default("cash")
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([date])
}

// ---- App Users (admin/staff) -------------------------------------------
model AppUser {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      String   @default("staff") // admin | staff
  password  String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---- Shop Settings (singleton) -----------------------------------------
model ShopSetting {
  id            String   @id @default(cuid())
  shopName      String   @default("ServingSync Restaurant")
  address       String?
  phone         String?
  email         String?
  gstin         String?
  taxRate       Float    @default(5)
  serviceRate   Float    @default(0)
  currency      String   @default("Rs.")
  invoicePrefix String   @default("INV")
  kotPrefix     String   @default("KOT")
  footerNote    String   @default("Thank you for dining with us!")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ---- Zomato Orders (aggregator) ----------------------------------------
// status: new | accepted | preparing | ready | dispatched | delivered | cancelled
// deliveryType: delivery | pickup | dinein
model ZomatoOrder {
  id             String   @id @default(cuid())
  zomatoOrderId  String   @unique // Zomato's order ID
  customerName   String
  customerPhone  String?
  deliveryType   String   @default("delivery") // delivery | pickup
  address        String?
  items          String   // JSON: [{ name, qty, price }]
  subtotal       Float
  taxAmount      Float    @default(0)
  packagingCharge Float   @default(0)
  deliveryFee    Float    @default(0)
  discount       Float    @default(0)
  total          Float
  paymentMode    String   @default("prepaid") // prepaid | cod
  status         String   @default("new")
  notes          String?
  internalOrderId String? // linked internal Order id once pushed to kitchen
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}
